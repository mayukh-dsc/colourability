{
  "name": "colourability",
  "version": "0.2.0",
  "description": "Color-blindness and grayscale filters for any webpage via SVG feColorMatrix",
  "type": "module",
  "main": "./dist/colourability.umd.cjs",
  "module": "./dist/colourability.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/colourability.esm.js",
      "require": "./dist/colourability.umd.cjs"
    }
  },
  "files": [
    "dist",
    "assets/logo.png"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js && tsc --emitDeclarationOnly --declaration --declarationMap --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "demo": "npx --yes serve . -p 4173"
  },
  "keywords": [
    "accessibility",
    "color-blindness",
    "daltonization",
    "svg",
    "filter"
  ],
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^3.0.5",
    "happy-dom": "^16.6.0",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
